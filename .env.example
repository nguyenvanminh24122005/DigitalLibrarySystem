# ============================================
# Digital Library System - Environment Variables
# Copy this file to .env and update values
# ============================================

# General
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Public URLs
PUBLIC_BASE_URL=http://localhost
FRONTEND_PORT=3000
GATEWAY_PORT=8080

# SQL Server
SA_PASSWORD=Your_password123
SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433

# Databases
CATALOG_DB=CatalogDB
CIRCULATION_DB=CirculationDB
IDENTITY_DB=IdentityDB

# JWT (shared across gateway + identity-service)
JWT_SECRET=change_this_to_a_long_secret_at_least_32_chars
JWT_ISSUER=DigitalLibrary
JWT_AUDIENCE=DigitalLibraryUsers

# Internal service URLs (Docker network)
CATALOG_SERVICE_URL=http://catalog-service:5001
CIRCULATION_SERVICE_URL=http://circulation-service:5002
IDENTITY_SERVICE_URL=http://identity-service:5003

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
